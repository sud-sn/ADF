{
    "name": "ST_SLS_FCY_DMS",
    "properties": {
        "folder": {
            "name": "Sales Schema/ST_SLS"
        },
        "type": "MappingDataFlow",
        "typeProperties": {
            "sources": [
                {
                    "dataset": {
                        "referenceName": "ST_CFACIL",
                        "type": "DatasetReference"
                    },
                    "name": "CFACIL",
                    "description": "Import data from ST_TD0_CFACIL"
                },
                {
                    "dataset": {
                        "referenceName": "SLS_PFT_CTR_DMS",
                        "type": "DatasetReference"
                    },
                    "name": "ProfitCentreDMS"
                }
            ],
            "sinks": [
                {
                    "dataset": {
                        "referenceName": "SLS_FCY_DMS",
                        "type": "DatasetReference"
                    },
                    "name": "sink1",
                    "description": "Export data to SLS_FCY_DMS",
                    "rejectedDataLinkedService": {
                        "referenceName": "AzureDataLakeStorage1",
                        "type": "LinkedServiceReference"
                    }
                }
            ],
            "transformations": [
                {
                    "name": "alterRow1"
                },
                {
                    "name": "join1"
                },
                {
                    "name": "derivedColumn2",
                    "description": "Creating/updating the columns 'PFT_CTR_DMS_KEY, AZ_EXT_ID'"
                },
                {
                    "name": "derivedColumn1"
                }
            ],
            "scriptLines": [
                "parameters{",
                "     Azure_Extract_ID as string",
                "}",
                "source(output(",
                "          FACI as string,",
                "          FACN as string,",
                "          DIVI as string,",
                "          GEOX as decimal(21,6),",
                "          GEOY as decimal(21,6)",
                "     ),",
                "     allowSchemaDrift: false,",
                "     validateSchema: true,",
                "     isolationLevel: 'READ_UNCOMMITTED',",
                "     query: 'SELECT DISTINCT [FACI],[FACN],[DIVI],[GEOX],[GEOY] FROM EMDW_STG_M3.[CFACIL]',",
                "     format: 'query') ~> CFACIL",
                "source(output(",
                "          PFT_CTR_DMS_KEY as integer,",
                "          PFT_CTR_CD as string",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     isolationLevel: 'READ_UNCOMMITTED',",
                "     query: 'SELECT [PFT_CTR_DMS_KEY], [PFT_CTR_CD] FROM [EMDW_DMART].[PFT_CTR_DMS]',",
                "     format: 'query') ~> ProfitCentreDMS",
                "derivedColumn2 alterRow(upsertIf(true())) ~> alterRow1",
                "derivedColumn1, ProfitCentreDMS join(trim(DIVI) == trim(PFT_CTR_CD),",
                "     joinType:'left',",
                "     matchType:'exact',",
                "     ignoreSpaces: false,",
                "     broadcast: 'auto')~> join1",
                "join1 derive(PFT_CTR_DMS_KEY = iif(equals(DIVI, '0'), 0, iif(equals(DIVI, PFT_CTR_CD), PFT_CTR_DMS_KEY, 777)),",
                "          AZ_EXT_ID = toString($Azure_Extract_ID)) ~> derivedColumn2",
                "CFACIL derive(DIVI = iif(isNull(DIVI) || trim(DIVI) == '', '0', DIVI)) ~> derivedColumn1",
                "alterRow1 sink(allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     input(",
                "          FCY_DMS_KEY as integer,",
                "          FCY_CD as string,",
                "          FCY_DSC as string,",
                "          PFT_CTR_DMS_KEY as integer,",
                "          GEO_LTD as decimal(21,6),",
                "          GEO_LGT as decimal(21,6),",
                "          AZ_LST_UPD_TS as timestamp,",
                "          AZ_LST_UPD_USR as string,",
                "          AZ_EXT_ID as string",
                "     ),",
                "     deletable:false,",
                "     insertable:false,",
                "     updateable:false,",
                "     upsertable:true,",
                "     keys:['FCY_CD'],",
                "     format: 'table',",
                "     batchSize: 50000,",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true,",
                "     errorHandlingOption: 'allErrors',",
                "     outputRejectedData: true,",
                "     rejectedData_fileSystem: 'bi-output',",
                "     rejectedData_folderPath: (concat('Fault_data/Stg_BI/', replace(toString(currentDate('UTC')), \"-\", \"\"), '/FCY_DMS_data')),",
                "     transactionCommit: 'batch',",
                "     reportSuccessOnError: true,",
                "     mapColumn(",
                "          FCY_CD = FACI,",
                "          FCY_DSC = FACN,",
                "          PFT_CTR_DMS_KEY,",
                "          GEO_LTD = GEOX,",
                "          GEO_LGT = GEOY,",
                "          AZ_EXT_ID",
                "     ),",
                "     partitionBy('roundRobin', 30)) ~> sink1"
            ]
        }
    }
}